# Copy to .env and fill in real values.
#
# Two databases live side by side in this one file:
#   MONGODB_URI_TEST → used when APP_ENV is development (npm run dev)
#   MONGODB_URI_PROD → used when APP_ENV is production  (npm start)
#
# On MongoDB Atlas you can use the SAME cluster with different database names:
#   .../test           and  .../dispatch_prod

PORT=4000

# Active DB is chosen automatically from APP_ENV (development | production)
MONGODB_URI_TEST=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/test?retryWrites=true&w=majority
MONGODB_URI_PROD=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/dispatch_prod?retryWrites=true&w=majority

# Optional legacy fallback (used if the env-specific one above is missing)
# MONGODB_URI=mongodb://localhost:27017/dispatch_testchec

JWT_ACCESS_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=7d

# Firebase Cloud Messaging — Android + web push (optional; in-app still works without)
FIREBASE_PROJECT_ID=your-firebase-project-id
# Origin of dev-lodgical for web push click URLs (no trailing slash)
# WEB_APP_ORIGIN=http://localhost:5173
# Paste the full service account JSON on one line, OR point to a gitignored file:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
